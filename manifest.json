{
  "manifest_version": 3,
  "name": "PT Gold",
  "version": "1.2.0",
  "description": "Certified moderator for the Phish forum on Phantasy Tour. Hide threads, posts, and quoted nests by keyword or user handle.",
  "permissions": ["storage", "alarms", "notifications", "sidePanel", "scripting"],
  "host_permissions": ["https://www.phantasytour.com/*", "https://api.giphy.com/*"],
  "action": {
    "default_title": "PT Gold — open panel",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": { "default_path": "dashboard.html" },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://www.phantasytour.com/bands/phish/*"],
      "js": ["content.js", "harvest.js", "imagify.js", "compose.js"],
      "css": ["content.css"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.phantasytour.com/bands/phish/*"],
      "js": ["discover.js"],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ]
}
